{
  "compilerOptions": {
    "target": "es6",
    "checkJs": true,
    "types": ["p5/global"],
    "module": "esnext",
    "lib": ["DOM", "ES6"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    // "*.ts",
    "sketch.ts",
    "**/*.ts",
    "src/**/*.ts"
    ],
"exclude": 
["node_modules", 
"libraries", 
"dist",
".vscode"]
}